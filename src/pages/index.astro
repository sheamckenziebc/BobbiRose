---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Bobbi Rose — Teetl'it Gwich'in River Guide, Artist & Land Protector"
  description="Teetl'it Gwich'in river guide, artist, mentor, and land protector based in Whitehorse, Yukon. Owner of Dinjii Zhuh Adventures."
>
  <Header slot="header" />

  <!-- HERO -->
  <section
    class="relative min-h-screen flex flex-col justify-center items-center text-center overflow-hidden"
    aria-label="Hero"
  >
    <!-- Static photo background — always visible, also serves as video poster fallback -->
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src={`${base}assets/image3.jpeg`}
        alt=""
        class="w-full h-full object-cover"
        style="object-position: 55% center;"
        fetchpriority="high"
      />
    </div>

    <!-- Video background — desktop only. Hidden on mobile (Safari iOS blocks autoplay bg video).
         Respects prefers-reduced-motion via inline script below. -->
    <video
      id="hero-video"
      class="absolute inset-0 w-full h-full object-cover hidden md:block"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
      style="object-position: center;"
    >
      <source src={`${base}assets/Video.mov`} type="video/quicktime" />
      <source src={`${base}assets/Video.mov`} type="video/mp4" />
    </video>

    <!-- Dark gradient overlay — ensures text readability over both photo and video -->
    <div
      class="absolute inset-0"
      aria-hidden="true"
      style="background: linear-gradient(160deg, rgba(10,22,28,0.72) 0%, rgba(20,40,52,0.60) 40%, rgba(28,55,68,0.55) 70%, rgba(36,62,52,0.58) 100%);"
    ></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-32 flex flex-col items-center">
      <!-- Label -->
      <p class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-gold); letter-spacing: 0.2em;">
        Teetl'it Gwich'in &middot; Whitehorse, Yukon
      </p>

      <!-- Headline -->
      <h1
        class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-light text-white mb-6 leading-tight"
        style="font-family: 'Cormorant Garamond', Georgia, serif; letter-spacing: -0.01em;"
      >
        Rooted in Rivers.<br/>
        <em class="font-light" style="color: rgba(255,255,255,0.82);">Led by Story.</em>
      </h1>

      <!-- Subhead -->
      <p class="text-base sm:text-lg lg:text-xl font-light max-w-2xl mb-10 leading-relaxed" style="color: rgba(250, 247, 240, 0.72);">
        River guide, mentor, artist, and land protector — bringing Gwich'in culture,
        community, and the wild north to life.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 items-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center px-8 py-3.5 rounded-lg font-semibold text-sm transition-all duration-200 hover:shadow-xl hover:-translate-y-0.5"
          style="background-color: var(--color-gold); color: var(--color-dark);"
        >
          Work With Bobbi Rose
        </a>
        <a
          href={`${base}work/`}
          class="inline-flex items-center px-8 py-3.5 rounded-lg font-semibold text-sm transition-all duration-200 hover:bg-white/10"
          style="border: 1px solid rgba(255,255,255,0.35); color: rgba(255,255,255,0.9);"
        >
          Explore the Work
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" aria-hidden="true" style="animation: bounce 2s infinite;">
      <span style="color: rgba(250,247,240,0.3); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;">Scroll</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: rgba(250,247,240,0.3);">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ABOUT / INTRO BLOCK -->
  <section class="py-20 lg:py-28 animate-on-scroll" style="background-color: var(--color-cream);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Left: Text -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-gold); letter-spacing: 0.15em;">About</p>
          <h2
            class="text-3xl sm:text-4xl lg:text-5xl font-light mb-6 leading-tight"
            style="font-family: 'Cormorant Garamond', Georgia, serif; color: var(--color-dark);"
          >
            A guide, a teacher, a keeper of story
          </h2>
          <div class="space-y-4 text-base leading-relaxed" style="color: var(--color-mid);">
            <p>
              Born and raised with deep roots in Teetl'it Zheh — Fort McPherson, NWT — and now based in
              Whitehorse, Yukon, Bobbi Rose carries forward the traditions of her Teetl'it Gwich'in heritage
              through every river she runs and every story she tells.
            </p>
            <p>
              As the owner of Dinjii Zhuh Adventures, she leads river journeys, youth programs, and community
              experiences grounded in land, water, and cultural knowledge. Her work spans guiding, mentorship,
              fashion, beadwork, and a growing voice in Indigenous tourism and water advocacy.
            </p>
            <p>
              When you step onto the water with Bobbi Rose, you are entering a living classroom — a space where
              the river teaches, the land remembers, and every person is welcomed into relationship with this place.
            </p>
          </div>
          <a
            href={`${base}about/`}
            class="inline-flex items-center gap-2 mt-8 font-medium text-sm transition-opacity hover:opacity-70"
            style="color: var(--color-river);"
          >
            Learn Bobbi Rose's Story
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <!-- Right: Portrait photo -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden" style="aspect-ratio: 3/4; max-height: 540px;">
            <img
              src={`${base}assets/image1.jpeg`}
              alt="Bobbi Rose smiling, wearing a floral headband"
              class="w-full h-full object-cover"
              style="object-position: 50% 20%;"
              loading="lazy"
            />
          </div>
          <!-- Caption label -->
          <div
            class="absolute bottom-4 left-4 right-4 rounded-xl px-4 py-3"
            style="background: rgba(26,22,20,0.72); backdrop-filter: blur(8px);"
          >
            <p class="text-xs uppercase tracking-widest mb-0.5" style="color: var(--color-gold); letter-spacing: 0.12em;">Dinjii Zhuh Adventures</p>
            <a
              href="https://www.dinjiizhuh.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-light text-white hover:opacity-75 transition-opacity"
              style="font-family: 'Cormorant Garamond', Georgia, serif;"
            >
              Owner &amp; Lead Guide — Where culture meets the current ↗
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED PATHWAYS / THE WORK -->
  <section
    class="py-20 lg:py-28 animate-on-scroll"
    style="background-color: var(--color-river);"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2
          class="text-4xl sm:text-5xl lg:text-6xl font-light text-white mb-4"
          style="font-family: 'Cormorant Garamond', Georgia, serif;"
        >
          The Work
        </h2>
        <p class="text-base font-light max-w-2xl mx-auto" style="color: rgba(250,247,240,0.6);">
          Every river, every workshop, every beaded piece carries the same intention.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">

        <!-- River Guiding -->
        <a
          href={`${base}work/`}
          class="group rounded-xl p-6 transition-all duration-300 card-hover animate-on-scroll"
          style="background: rgba(250,247,240,0.05); border: 1px solid rgba(250,247,240,0.1);"
        >
          <div
            class="w-12 h-12 rounded-lg flex items-center justify-center mb-5"
            style="background: linear-gradient(135deg, rgba(196,145,58,0.25), rgba(196,145,58,0.08));"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-gold);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 17c1.5-1.5 3-1.5 4.5 0S11 18.5 12.5 17s3-1.5 4.5 0 3 1.5 4.5 0M3 12c1.5-1.5 3-1.5 4.5 0S11 13.5 12.5 12s3-1.5 4.5 0 3 1.5 4.5 0M3 7c1.5-1.5 3-1.5 4.5 0S11 8.5 12.5 7s3-1.5 4.5 0 3 1.5 4.5 0"/>
            </svg>
          </div>
          <h3
            class="text-xl font-medium text-white mb-2"
            style="font-family: 'Cormorant Garamond', Georgia, serif;"
          >
            River Guiding
          </h3>
          <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,240,0.58);">
            Multi-day river expeditions through Yukon and NWT. Gwich'in-led, land-based, culturally grounded.
          </p>
          <span class="text-xs font-medium" style="color: var(--color-gold);">Explore &rarr;</span>
        </a>

        <!-- Youth & Community -->
        <a
          href={`${base}work/`}
          class="group rounded-xl p-6 transition-all duration-300 card-hover animate-on-scroll"
          style="background: rgba(250,247,240,0.05); border: 1px solid rgba(250,247,240,0.1);"
        >
          <div
            class="w-12 h-12 rounded-lg flex items-center justify-center mb-5"
            style="background: linear-gradient(135deg, rgba(196,145,58,0.25), rgba(196,145,58,0.08));"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-gold);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3
            class="text-xl font-medium text-white mb-2"
            style="font-family: 'Cormorant Garamond', Georgia, serif;"
          >
            Youth &amp; Community
          </h3>
          <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,240,0.58);">
            Mentorship programs, youth river guide training, and community-based trips that pass knowledge forward.
          </p>
          <span class="text-xs font-medium" style="color: var(--color-gold);">Explore &rarr;</span>
        </a>

        <!-- Art & Fashion -->
        <a
          href={`${base}shop/`}
          class="group rounded-xl p-6 transition-all duration-300 card-hover animate-on-scroll"
          style="background: rgba(250,247,240,0.05); border: 1px solid rgba(250,247,240,0.1);"
        >
          <div
            class="w-12 h-12 rounded-lg flex items-center justify-center mb-5"
            style="background: linear-gradient(135deg, rgba(196,145,58,0.25), rgba(196,145,58,0.08));"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-gold);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3
            class="text-xl font-medium text-white mb-2"
            style="font-family: 'Cormorant Garamond', Georgia, serif;"
          >
            Art &amp; Fashion
          </h3>
          <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,240,0.58);">
            Beadwork, collaborative fashion, and creative projects rooted in Gwich'in aesthetics and northern land.
          </p>
          <span class="text-xs font-medium" style="color: var(--color-gold);">Explore &rarr;</span>
        </a>

        <!-- Media & Research -->
        <a
          href={`${base}media/`}
          class="group rounded-xl p-6 transition-all duration-300 card-hover animate-on-scroll"
          style="background: rgba(250,247,240,0.05); border: 1px solid rgba(250,247,240,0.1);"
        >
          <div
            class="w-12 h-12 rounded-lg flex items-center justify-center mb-5"
            style="background: linear-gradient(135deg, rgba(196,145,58,0.25), rgba(196,145,58,0.08));"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-gold);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3
            class="text-xl font-medium text-white mb-2"
            style="font-family: 'Cormorant Garamond', Georgia, serif;"
          >
            Media &amp; Research
          </h3>
          <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,240,0.58);">
            Features, interviews, film, and academic work that amplifies Indigenous voices and land-based perspectives.
          </p>
          <span class="text-xs font-medium" style="color: var(--color-gold);">Explore &rarr;</span>
        </a>

      </div>
    </div>
  </section>

  <!-- QUOTE / PHILOSOPHY -->
  <section
    class="py-24 lg:py-32 relative overflow-hidden animate-on-scroll"
    style="background: linear-gradient(160deg, #1A1614 0%, #2D2218 50%, #1E3D4F 100%);"
  >
    <div class="absolute inset-0 pointer-events-none" style="opacity: 0.05;" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="quotewaves" x="0" y="0" width="300" height="80" patternUnits="userSpaceOnUse">
            <path d="M0 40 Q75 20 150 40 Q225 60 300 40" stroke="#C4913A" stroke-width="1.2" fill="none"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#quotewaves)"/>
      </svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-4 mb-10" aria-hidden="true">
        <div class="h-px w-16" style="background: var(--color-gold); opacity: 0.45;"></div>
        <div class="w-1.5 h-1.5 rounded-full" style="background: var(--color-gold);"></div>
        <div class="h-px w-16" style="background: var(--color-gold); opacity: 0.45;"></div>
      </div>

      <blockquote>
        <p
          class="text-3xl sm:text-4xl lg:text-5xl font-light italic text-white leading-snug mb-8"
          style="font-family: 'Cormorant Garamond', Georgia, serif;"
        >
          &ldquo;The river doesn't ask if you're ready. It just takes you where you need to go.&rdquo;
        </p>
        <footer>
          <cite
            class="text-sm font-medium not-italic"
            style="color: var(--color-gold); letter-spacing: 0.1em;"
          >
            &mdash; Bobbi Rose
          </cite>
        </footer>
      </blockquote>

      <div class="flex items-center justify-center gap-4 mt-10" aria-hidden="true">
        <div class="h-px w-16" style="background: var(--color-gold); opacity: 0.45;"></div>
        <div class="w-1.5 h-1.5 rounded-full" style="background: var(--color-gold);"></div>
        <div class="h-px w-16" style="background: var(--color-gold); opacity: 0.45;"></div>
      </div>
    </div>
  </section>

  <!-- FEATURED MEDIA & PRESS -->
  <section class="py-20 lg:py-28 animate-on-scroll" style="background-color: var(--color-cream);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold); letter-spacing: 0.15em;">In the World</p>
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <h2
            class="text-3xl sm:text-4xl lg:text-5xl font-light"
            style="font-family: 'Cormorant Garamond', Georgia, serif; color: var(--color-dark);"
          >
            Stories That Travel
          </h2>
          <a
            href={`${base}media/`}
            class="self-start sm:self-auto text-sm font-medium transition-opacity hover:opacity-70"
            style="color: var(--color-river);"
          >
            View All Media &rarr;
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">

        <!-- Manitobah -->
        <div class="rounded-xl overflow-hidden animate-on-scroll card-hover" style="border: 1px solid var(--color-stone); background: white;">
          <div class="h-36 flex items-end p-5" style="background: linear-gradient(135deg, #2D4A3E 0%, #1E3D4F 100%);">
            <span class="text-xs font-semibold uppercase tracking-widest px-2.5 py-1 rounded" style="background: rgba(196,145,58,0.2); color: var(--color-gold); letter-spacing: 0.1em; border: 1px solid rgba(196,145,58,0.3);">
              Feature
            </span>
          </div>
          <div class="p-6">
            <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: var(--color-earth);">Manitobah</p>
            <h3 class="text-lg font-medium mb-3 leading-snug" style="font-family: 'Cormorant Garamond', Georgia, serif; color: var(--color-dark);">
              Celebrating World Water Day 2025
            </h3>
            <p class="text-sm leading-relaxed mb-5" style="color: var(--color-mid);">
              A feature on Bobbi Rose's connection to water, Gwich'in culture, and the World Water Day 2025 collaboration.
            </p>
            <a
              href="https://www.manitobah.ca/blogs/stories/celebrating-world-water-day-2025-manitobah-x-brk"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-medium transition-opacity hover:opacity-70"
              style="color: var(--color-river);"
            >
              Read Feature ↗
            </a>
          </div>
        </div>

        <!-- National Geographic -->
        <div class="rounded-xl overflow-hidden animate-on-scroll card-hover" style="border: 1px solid var(--color-stone); background: white;">
          <div class="h-36 flex items-end p-5" style="background: linear-gradient(135deg, #1E3D4F 0%, #0F2027 100%);">
            <span class="text-xs font-semibold uppercase tracking-widest px-2.5 py-1 rounded" style="background: rgba(44,95,122,0.3); color: rgba(250,247,240,0.8); letter-spacing: 0.1em; border: 1px solid rgba(44,95,122,0.4);">
              Watch
            </span>
          </div>
          <div class="p-6">
            <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: var(--color-earth);">National Geographic</p>
            <h3 class="text-lg font-medium mb-3 leading-snug" style="font-family: 'Cormorant Garamond', Georgia, serif; color: var(--color-dark);">
              2024 NWT/Yukon Film Adventure
            </h3>
            <p class="text-sm leading-relaxed mb-5" style="color: var(--color-mid);">
              A film journey through the northwest — the 2024 National Geographic and NWT/Yukon collaboration.
            </p>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium" style="color: rgba(74,55,40,0.38);">
              Film coming soon
            </span>
          </div>
        </div>

        <!-- Frontiers -->
        <div class="rounded-xl overflow-hidden animate-on-scroll card-hover" style="border: 1px solid var(--color-stone); background: white;">
          <div class="h-36 flex items-end p-5" style="background: linear-gradient(135deg, #4A3728 0%, #2D4A3E 100%);">
            <span class="text-xs font-semibold uppercase tracking-widest px-2.5 py-1 rounded" style="background: rgba(139,99,71,0.2); color: rgba(250,247,240,0.8); letter-spacing: 0.1em; border: 1px solid rgba(139,99,71,0.3);">
              Research
            </span>
          </div>
          <div class="p-6">
            <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: var(--color-earth);">Frontiers in Sustainable Tourism</p>
            <h3 class="text-lg font-medium mb-3 leading-snug" style="font-family: 'Cormorant Garamond', Georgia, serif; color: var(--color-dark);">
              Indigenous Land-Based Guiding
            </h3>
            <p class="text-sm leading-relaxed mb-5" style="color: var(--color-mid);">
              Academic research on Indigenous land-based guiding, cultural continuity, and sustainable tourism.
            </p>
            <a
              href="https://www.frontiersin.org/journals/sustainable-tourism/articles/10.3389/frsut.2024.1414416/abstract"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-medium transition-opacity hover:opacity-70"
              style="color: var(--color-river);"
            >
              Read Research ↗
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SHOP / COLLABORATIONS TEASER -->
  <section class="py-20 lg:py-28 animate-on-scroll" style="background-color: var(--color-dark);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold); letter-spacing: 0.15em;">Collaborations</p>
        <h2
          class="text-3xl sm:text-4xl lg:text-5xl font-light text-white mb-4"
          style="font-family: 'Cormorant Garamond', Georgia, serif;"
        >
          Wear the Story
        </h2>
        <p class="text-sm sm:text-base font-light max-w-xl mx-auto" style="color: rgba(232,224,213,0.58);">
          Curated pieces that carry the land forward — from beadwork to apparel,
          each collaboration is a conversation between culture and craft.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto mb-10 stagger-children">

        <a
          href="https://yukonapparel.ca/products/river-beautyyy-creations"
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-xl p-7 transition-all duration-300 card-hover animate-on-scroll"
          style="background: rgba(250,247,240,0.04); border: 1px solid rgba(250,247,240,0.1);"
        >
          <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(196,145,58,0.15);">
