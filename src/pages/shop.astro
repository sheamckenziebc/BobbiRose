---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Shop & Collaborations — Bobbi Rose"
  description="Curated pieces and partnerships rooted in Gwich'in identity, northern landscape, and intentional craft. River Beautyyy × Yukon Apparel and Dinjii Zhuh Adventures store."
>
  <Header slot="header" />

  <!-- HERO -->
  <section
    class="relative pt-36 pb-20 flex flex-col justify-end overflow-hidden"
    style="background: linear-gradient(160deg, #4A3728 0%, #2D4A3E 40%, #1E3D4F 100%); min-height: 50vh;"
  >
    <div class="absolute inset-0 pointer-events-none" style="opacity: 0.09;" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
        <defs>
          <pattern id="shop-waves" x="0" y="0" width="200" height="60" patternUnits="userSpaceOnUse">
            <path d="M0 30 Q25 20 50 30 Q75 40 100 30 Q125 20 150 30 Q175 40 200 30" stroke="rgba(196,145,58,0.7)" stroke-width="0.8" fill="none"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#shop-waves)"/>
      </svg>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-xs" style="color: rgba(250,247,240,0.4);">
          <li><a href={base} class="hover:opacity-80 transition-opacity">Home</a></li>
          <li aria-hidden="true">/</li>
          <li style="color: var(--color-gold);">Shop</li>
        </ol>
      </nav>
      <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-gold); letter-spacing: 0.2em;">Shop &amp; Collaborations</p>
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-light text-white mb-4 leading-tight"
        style="font-family: 'Cormorant Garamond', Georgia, serif;"
      >
        Wear the Story.<br/><em class="font-light">Support the Work.</em>
      </h1>
      <p class="text-base font-light max-w-2xl" style="color: rgba(250,247,240,0.62);">
        Curated pieces and partnerships rooted in Gwich'in identity, northern landscape, and intentional craft. Not a storefront — a collection of aligned collaborations.
      </p>
    </div>
  </section>

  <!-- APPAREL: RIVER BEAUTYYY × YUKON APPAREL -->
  <section class="py-20 lg:py-28 animate-on-scroll" style="background-color: var(--color-cream);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-gold); letter-spacing: 0.15em;">Wear</p>
          <h2
            class="text-3xl sm:text-4xl font-light mb-6 leading-tight"
            style="font-family: 'Cormorant Garamond', Georgia, serif; color: var(--color-dark);"
          >
            River Beautyyy &times; Yukon Apparel
          </h2>
          <p class="text-base leading-relaxed mb-8" style="color: var(--color-mid);">
            Bobbi Rose's River Beautyyy collaboration with Yukon Apparel brings Gwich'in-influenced design into apparel form. Wear something that carries a story from the north.
          </p>
          <a
            href="https://yukonapparel.ca/products/river-beautyyy-creations"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold transition-all hover:opacity-90"
            style="background-color: var(--color-gold); color: var(--color-dark);"
          >
            Shop the Collection ↗
          </a>
        </div>
        <div
          class="rounded-2xl overflow-hidden flex items-end"
          style="background: linear-gradient(160deg, #4A3728 0%, #2D4A3E 100%); min-height: 320px; position: relative;"
        >
          <div class="absolute inset-0 pointer-events-none" style="opacity: 0.1;" aria-hidden="true">
            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="apparel-waves" x="0" y="0" width="120" height="40" patternUnits="userSpaceOnUse">
                  <path d="M0 20 Q30 10 60 20 Q90 30 120 20" stroke="#C4913A" stroke-width="1.2" fill="none"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#apparel-waves)"/>
            </svg>
          </div>
          <div class="relative z-10 p-8">
            <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-gold); letter-spacing: 0.15em; opacity: 0.7;">River Beautyyy</p>
            <p class="text-sm" style="color: rgba(250,247,240,0.35);">Image to be added</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DINJII ZHUH STORE -->
  <section
    class="py-20 lg:py-24 animate-on-scroll"
    style="background-color: var(--color-river);"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div
          class="rounded-2xl overflow-hidden flex items-end lg:order-first"
          style="background: linear-gradient(160deg, #1E3D4F 0%, #2D4A3E 100%); min-height: 320px; position: relative;"
        >
          <div class="absolute inset-0 pointer-events-none" style="opacity: 0.1;" aria-hidden="true">
            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="dinjii-waves" x="0" y="0" width="120" height="40" patternUnits="userSpaceOnUse">
                  <path d="M0 20 Q30 10 60 20 Q90 30 120 20" stroke="#C4913A" stroke-width="1.2" fill="none"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#dinjii-waves)"/>
            </svg>
          </div>
          <div class="relative z-10 p-8">
            <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-gold); letter-spacing: 0.15em; opacity: 0.7;">Dinjii Zhuh</p>
            <p class="text-sm" style="color: rgba(250,247,240,0.35);">Image to be added</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-gold); letter-spacing: 0.15em;">Dinjii Zhuh</p>
          <h2
            class="text-3xl sm:text-4xl font-light text-white mb-6 leading-tight"
            style="font-family: 'Cormorant Garamond', Georgia, serif;"
          >
            The Dinjii Zhuh Store
          </h2>
          <p class="text-base leading-relaxed mb-8" style="color: rgba(250,247,240,0.68);">
            Goods, apparel, and cultural items available through the Dinjii Zhuh Adventures store. Supporting Bobbi Rose's guiding work and community programming directly.
          </p>
          <a
            href="https://www.dinjiizhuh.com/store"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold transition-all hover:opacity-90"
            style="background-color: var(--color-gold); color: var(--color-dark);"
          >
            Visit the Store ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- UNORTHODOX YUKON -->
  <section class="py-20 lg:py-24 animate-on-scroll" style="background-color: var(--color-cream);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-gold); letter-spacing: 0.15em;">Collaboration</p>
        <h2
          class="text-3xl sm:text-4xl font-light mb-6 leading-tight"
          style="font-family: 'Cormorant Garamond', Georgia, serif; color: var(--color-dark);"
        >
          Unorthodox Yukon
        </h2>
        <p class="text-base leading-relaxed mb-8" style="color: var(--color-mid);">
          A Whitehorse-based creative brand. Collaboration details coming soon.
        </p>
        <a
          href="https://unorthodoxyukon.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold transition-all hover:opacity-80"
          style="border: 1px solid rgba(30,61,79,0.25); color: var(--color-river);"
        >
          Explore Unorthodox Yukon ↗
        </a>
      </div>
    </div>
  </section>

  <!-- NOTE ON SHOPPING -->
  <section class="py-16 animate-on-scroll" style="background-color: var(--color-stone);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-xl p-8"
        style="background: rgba(255,255,255,0.6); border: 1px solid rgba(196,145,58,0.2);"
      >
        <div class="flex gap-3 items-start">
          <div
            class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5"
            style="background: rgba(196,145,58,0.15);"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-gold);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold mb-2" style="color: var(--color-dark);">A note on shopping</p>
            <p class="text-sm leading-relaxed" style="color: var(--color-mid);">
              These links represent aligned collaborations that Bobbi Rose has chosen to stand behind. They are curated intentionally — not a referral list. When you shop through these links, you are supporting the ecosystem of Indigenous-owned and northern-aligned creative work.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
