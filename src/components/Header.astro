---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';
import Breadcrumbs from './Breadcrumbs.astro';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header class="bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 sticky top-0 z-50 transition-all duration-300" id="site-header">
  <!-- Top bar with contact info (desktop only) -->
  <div class="hidden lg:block bg-slate-900 text-white text-sm" id="top-bar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center py-2">
      <div class="flex items-center gap-6">
        <a href={`tel:${config.contact.phone}`} class="flex items-center gap-1.5 hover:text-amber-400 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {config.contact.phone}
        </a>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {config.contact.businessHours}
        </span>
      </div>
      <div class="flex items-center gap-4">
        {config.social.facebook && (
          <a href={config.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-amber-400 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
          </a>
        )}
        {config.social.instagram && (
          <a href={config.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-amber-400 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987s11.987-5.367 11.987-11.987C24.004 5.367 18.637.001 12.017.001zM8.449 16.988c-1.297 0-2.448-.49-3.328-1.297C4.243 14.814 3.5 13.455 3.5 11.987s.743-2.827 1.621-3.704c.88-.807 2.031-1.297 3.328-1.297 1.297 0 2.448.49 3.328 1.297.878.877 1.621 2.236 1.621 3.704s-.743 2.827-1.621 3.704c-.88.807-2.031 1.297-3.328 1.297z" clip-rule="evenodd"/></svg>
          </a>
        )}
        {config.social.linkedin && (
          <a href={config.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-amber-400 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" clip-rule="evenodd"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 lg:h-18">
      <!-- Logo -->
      <div class="flex items-center">
        <a href={base} class="flex items-center space-x-2 group" aria-label="Home">
          <img
            src={`${base}assets/logo.svg`}
            alt={`${config.site.title} logo`}
            class="h-9 w-auto transition-transform group-hover:scale-105"
            width="36"
            height="36"
          />
          <div class="flex flex-col">
            <span class="text-lg font-extrabold text-gray-900 leading-tight">{config.site.title}</span>
            <span class="text-[10px] text-gray-500 font-medium uppercase tracking-widest hidden sm:block">General Contractor</span>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        <ul class="flex items-center gap-1" role="menubar">
          <li role="none">
            <a
              href={base}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath === base || currentPath === base.slice(0, -1) ? 'text-blue-700 bg-blue-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}
            >
              Home
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}about/`}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'text-blue-700 bg-blue-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}
            >
              About
            </a>
          </li>
          {config.features.products && (
            <li role="none">
              <a
                href={`${base}services/`}
                class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.includes('/services') ? 'text-blue-700 bg-blue-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
                role="menuitem"
                aria-current={currentPath.includes('/services') ? 'page' : undefined}
              >
                Services
              </a>
            </li>
          )}
          {config.features.blog && (
            <li role="none">
              <a
                href={`${base}blog/`}
                class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.includes('/blog') ? 'text-blue-700 bg-blue-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
                role="menuitem"
                aria-current={currentPath.includes('/blog') ? 'page' : undefined}
              >
                Blog
              </a>
            </li>
          )}
          <li role="none">
            <a
              href={`${base}templates/`}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.includes('/templates') ? 'text-blue-700 bg-blue-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath.includes('/templates') ? 'page' : undefined}
            >
              Templates
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}contact/`}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'text-blue-700 bg-blue-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}
            >
              Contact
            </a>
          </li>
        </ul>
        <!-- Desktop CTA -->
        <a
          href={`${base}contact/`}
          class="ml-4 inline-flex items-center bg-amber-500 text-slate-900 px-5 py-2.5 rounded-lg font-bold text-sm hover:bg-amber-400 transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5"
        >
          Free Estimate
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center gap-3">
        <a href={`tel:${config.contact.phone}`} class="text-blue-600 p-2" aria-label="Call us">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </a>
        <button
          type="button"
          class="text-gray-700 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 p-2 rounded-lg"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle mobile menu"
          id="mobile-menu-button"
        >
          <svg class="h-6 w-6 menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="h-6 w-6 close-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden overflow-hidden transition-all duration-300 max-h-0" id="mobile-menu">
      <div class="px-2 pt-2 pb-4 space-y-1 border-t border-gray-100">
        <a
          href={base}
          class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath === base || currentPath === base.slice(0, -1) ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50'}`}
          aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}
        >
          Home
        </a>
        <a
          href={`${base}about/`}
          class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50'}`}
          aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}
        >
          About
        </a>
        {config.features.products && (
          <a
            href={`${base}services/`}
            class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.includes('/services') ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50'}`}
            aria-current={currentPath.includes('/services') ? 'page' : undefined}
          >
            Services
          </a>
        )}
        {config.features.blog && (
          <a
            href={`${base}blog/`}
            class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.includes('/blog') ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50'}`}
            aria-current={currentPath.includes('/blog') ? 'page' : undefined}
          >
            Blog
          </a>
        )}
        <a
          href={`${base}templates/`}
          class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.includes('/templates') ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50'}`}
          aria-current={currentPath.includes('/templates') ? 'page' : undefined}
        >
          Templates
        </a>
        <a
          href={`${base}contact/`}
          class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50'}`}
          aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}
        >
          Contact
        </a>
        <a
          href={`${base}contact/`}
          class="block mx-2 mt-3 text-center bg-amber-500 text-slate-900 px-4 py-3 rounded-lg font-bold hover:bg-amber-400 transition-colors"
        >
          Get a Free Estimate
        </a>
      </div>
    </div>
  </div>

  <!-- Breadcrumbs (for non-home pages) -->
  {currentPath !== base && currentPath !== base.slice(0, -1) && <Breadcrumbs />}
</header>

<script>
  function initHeader() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = mobileMenuButton?.querySelector('.menu-icon');
    const closeIcon = mobileMenuButton?.querySelector('.close-icon');

    function closeMenu() {
      if (!mobileMenuButton || !mobileMenu) return;
      mobileMenuButton.setAttribute('aria-expanded', 'false');
      mobileMenu.style.maxHeight = '0';
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', () => {
        const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
        mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded));

        if (isExpanded) {
          closeMenu();
        } else {
          mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        }
      });

      // Close menu on outside click
      document.addEventListener('click', (e) => {
        if (mobileMenuButton.getAttribute('aria-expanded') === 'true'
            && !mobileMenu.contains(e.target as Node)
            && !mobileMenuButton.contains(e.target as Node)) {
          closeMenu();
        }
      });

      // Close menu on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenuButton.getAttribute('aria-expanded') === 'true') {
          closeMenu();
          mobileMenuButton.focus();
        }
      });

      // Close menu when a nav link is clicked
      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMenu);
      });
    }

    // Header shrink on scroll
    const header = document.getElementById('site-header');
    const topBar = document.getElementById('top-bar');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header.classList.add('shadow-md');
          topBar?.classList.add('hidden');
        } else {
          header.classList.remove('shadow-md');
          topBar?.classList.remove('hidden');
        }
      }, { passive: true });
    }
  }

  // Re-init on View Transitions navigation
  document.addEventListener('astro:page-load', initHeader);
</script>
