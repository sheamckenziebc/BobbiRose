---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
---

<footer style="background-color: var(--color-dark); color: var(--color-stone);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">

      <!-- Left: Identity -->
      <div class="lg:col-span-1">
        <p
          class="text-3xl font-light mb-2"
          style="font-family: 'Cormorant Garamond', Georgia, serif; color: #FAF7F0; letter-spacing: 0.02em;"
        >
          Bobbi Rose
        </p>
        <p class="text-sm mb-4" style="color: var(--color-gold); letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem;">
          Teetl'it Gwich'in. Culture. Land. Rivers.
        </p>
        <p class="text-sm leading-relaxed mb-6" style="color: rgba(232, 224, 213, 0.7);">
          River guide, mentor, artist, and land protector based in Whitehorse, Yukon.
          Owner of Dinjii Zhuh Adventures. Carrying Gwich'in knowledge forward
          through every river journey and story shared.
        </p>
        <a
          href={`mailto:${config.contact.email}`}
          class="text-sm transition-colors hover:opacity-100"
          style="color: var(--color-gold); opacity: 0.85;"
        >
          {config.contact.email}
        </a>
      </div>

      <!-- Middle: Quick Links -->
      <div>
        <h3
          class="text-xs font-semibold uppercase tracking-widest mb-6"
          style="color: rgba(232, 224, 213, 0.5);"
        >
          Navigate
        </h3>
        <ul class="space-y-3 text-sm">
          {[
            { label: 'About', href: `${base}about/` },
            { label: 'Work', href: `${base}work/` },
            { label: 'Media', href: `${base}media/` },
            { label: 'Shop', href: `${base}shop/` },
            { label: 'Contact', href: `${base}contact/` },
          ].map((link) => (
            <li>
              <a
                href={link.href}
                class="transition-colors"
                style="color: rgba(232, 224, 213, 0.65);"
                onmouseover="this.style.color='#FAF7F0'"
                onmouseout="this.style.color='rgba(232, 224, 213, 0.65)'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <h3
            class="text-xs font-semibold uppercase tracking-widest mb-4"
            style="color: rgba(232, 224, 213, 0.5);"
          >
            Elsewhere
          </h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href="https://www.dinjiizhuh.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="transition-colors"
                style="color: rgba(232, 224, 213, 0.65);"
                onmouseover="this.style.color='#C4913A'"
                onmouseout="this.style.color='rgba(232, 224, 213, 0.65)'"
              >
                Dinjii Zhuh Adventures ↗
              </a>
            </li>
            <li>
              <a
                href="https://nahanni.com/guide/bobbi-rose-koe/"
                target="_blank"
                rel="noopener noreferrer"
                class="transition-colors"
                style="color: rgba(232, 224, 213, 0.65);"
                onmouseover="this.style.color='#C4913A'"
                onmouseout="this.style.color='rgba(232, 224, 213, 0.65)'"
              >
                Nahanni River Adventures ↗
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Right: Social -->
      <div>
        <h3
          class="text-xs font-semibold uppercase tracking-widest mb-6"
          style="color: rgba(232, 224, 213, 0.5);"
        >
          Connect
        </h3>
        <div class="space-y-4">

          <!-- Instagram -->
          {config.contact.instagram && (
            <a
              href={config.contact.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 group"
            >
              <div
                class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors"
                style="background: rgba(232, 224, 213, 0.08);"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: rgba(232,224,213,0.6);">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium" style="color: rgba(232,224,213,0.85);">Instagram</p>
                <p class="text-xs" style="color: rgba(232,224,213,0.45);">@river.beautyyy</p>
              </div>
            </a>
          )}

          <!-- Facebook -->
          {config.contact.facebook && (
            <a
              href={config.contact.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 group"
            >
              <div
                class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors"
                style="background: rgba(232, 224, 213, 0.08);"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: rgba(232,224,213,0.6);">
                  <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium" style="color: rgba(232,224,213,0.85);">Facebook</p>
                <p class="text-xs" style="color: rgba(232,224,213,0.45);">Bobbi Rose</p>
              </div>
            </a>
          )}

          <!-- TikTok -->
          {config.contact.tiktok && (
            <a
              href={config.contact.tiktok}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 group"
            >
              <div
                class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors"
                style="background: rgba(232, 224, 213, 0.08);"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: rgba(232,224,213,0.6);">
                  <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium" style="color: rgba(232,224,213,0.85);">TikTok</p>
                <p class="text-xs" style="color: rgba(232,224,213,0.45);">@river.beautyyy</p>
              </div>
            </a>
          )}

          <!-- Spotify -->
          {config.contact.spotify && (
            <a
              href={config.contact.spotify}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 group"
            >
              <div
                class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors"
                style="background: rgba(232, 224, 213, 0.08);"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: rgba(232,224,213,0.6);">
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium" style="color: rgba(232,224,213,0.85);">Spotify Playlist</p>
                <p class="text-xs" style="color: rgba(232,224,213,0.45);">Bobbi Rose's mix</p>
              </div>
            </a>
          )}

        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div style="border-top: 1px solid rgba(232, 224, 213, 0.1);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-xs" style="color: rgba(232, 224, 213, 0.4);">
      <div class="flex flex-col sm:flex-row gap-1 sm:gap-4">
        <span>&copy; 2025 Bobbi Rose Koe. Teetl'it Gwich'in Territory.</span>
        <a
          href="https://www.dinjiizhuh.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:opacity-80"
          style="color: rgba(196, 145, 58, 0.7);"
        >
          Dinjii Zhuh Adventures ↗
        </a>
      </div>
      <a
        href="https://www.whose.land/en/"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:opacity-80"
        style="color: rgba(232, 224, 213, 0.4);"
      >
        Learn whose land you're on ↗
      </a>
    </div>
  </div>
</footer>
